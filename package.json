{
  "scripts": {
    "dev": "concurrently -k -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python -m uvicorn backend.app.main:app --host 0.0.0.0 --port 8008",
    "dev:backend:reload": "python -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8008",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "stop:dev": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "test": "python -m unittest discover -s tests",
    "build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
